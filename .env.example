# Market data provider
DATA_PROVIDER=synthetic
DATA_API_KEY=your_data_api_key_here
# Set DATA_PROVIDER=alpaca to use real historical bars for backtests.
ALPACA_API_KEY=
ALPACA_API_SECRET=
ALPACA_DATA_BASE_URL=https://data.alpaca.markets
ALPACA_DATA_FEED=iex

# Execution/Broker configuration (paper-only by default).
# ALPACA_BASE_URL is the canonical execution base URL for Alpaca-compatible routing.
# Current execution remains in-process paper simulation until a broker adapter is enabled.
ALPACA_BASE_URL=https://paper-api.alpaca.markets
# Temporary legacy alias (prefer ALPACA_API_SECRET):
# ALPACA_SECRET_KEY=

# Deployment/runtime
APP_ENV=development
SERVICE_NAME=trauto
HOST=0.0.0.0
PORT=8000
DATABASE_URL=sqlite+pysqlite:///data/trauto.db
STRICT_ENV_VALIDATION=false
RUN_MIGRATIONS_ON_STARTUP=true
LIVE_TRADING=false
# Comma-separated list. For Render static frontend use:
# CORS_ALLOWED_ORIGINS=https://trauto.onrender.com
CORS_ALLOWED_ORIGINS=http://localhost:3000
LOG_DIR=logs
CACHE_DIR=data/cache

# Authentication (single-user admin, future-ready roles)
AUTH_ENABLED=true
# Use long random secrets in production/staging (>=32 chars).
AUTH_SESSION_SECRET=replace-with-a-long-random-session-secret
AUTH_PASSWORD_PEPPER=replace-with-a-long-random-password-pepper
AUTH_SESSION_TTL_MINUTES=720
AUTH_LOGIN_MAX_ATTEMPTS=5
AUTH_LOGIN_WINDOW_SECONDS=900
AUTH_LOGIN_BLOCK_SECONDS=900
# Optional startup bootstrap (safe for first deploy only):
AUTH_BOOTSTRAP_ADMIN_ON_STARTUP=false
AUTH_BOOTSTRAP_ADMIN_EMAIL=
AUTH_BOOTSTRAP_ADMIN_PASSWORD=

# Optional runtime overrides
INITIAL_CAPITAL=100000
POSITION_SIZE_PCT=1.0
FIXED_FEE=1.0
SLIPPAGE_PCT=0.0005
# Leave blank to disable stop loss / take profit.
STOP_LOSS_PCT=
TAKE_PROFIT_PCT=
MAX_POSITION_SIZE=0.25
MAX_DAILY_LOSS=2000
PAPER_TRADING=false
MAX_NOTIONAL_PER_TRADE=100000
MAX_OPEN_POSITIONS=3
EXECUTOR_DAILY_LOSS_CAP=2000
TRADE_LOG_PATH=logs/trades.csv

# Worker controls (paper-only)
WORKER_NAME=default-worker
WORKER_ENABLE_TRADING=false
EXECUTION_PROFILE=conservative
WORKER_POLL_SECONDS=60
# Universe mode: static | top_gainers | top_losers | high_relative_volume | index_constituents
WORKER_UNIVERSE_MODE=static
# Max symbols that proceed to strategy evaluation each cycle.
WORKER_MAX_CANDIDATES=10
# Strategy selection gate: minimum recent trades required once warm-up ends.
SELECTION_MIN_RECENT_TRADES=5
# Startup warm-up cycles: during warm-up, insufficient_recent_trades gate is bypassed.
WORKER_STARTUP_WARMUP_CYCLES=20
# Explicit ticker universe (comma-separated).
# Used directly in static mode and as scan input for other modes.
WORKER_SYMBOLS=SPY,QQQ,NVDA,TSLA,AMD,AAPL,META,AMZN,MSFT,GOOGL
# Optional legacy single-symbol fallback (used when WORKER_SYMBOLS is blank).
WORKER_SYMBOL=SPY
WORKER_TIMEFRAME=1d
WORKER_STRATEGY=moving_average_crossover
WORKER_STRATEGY_PARAMS_JSON={}
WORKER_ORDER_QUANTITY=1.0
WORKER_FORCE_REFRESH=false
# Dry-run executes full scan/filter/select flow but never submits orders.
WORKER_DRY_RUN=true
# Keep false by default: only one active strategy may manage each symbol position.
WORKER_ALLOW_MULTI_STRATEGY_PER_SYMBOL=false
# Scanner safety filters
MIN_PRICE=1.0
# Average shares per day. Intraday scans sum bars into market-day totals first.
MIN_AVG_VOLUME=100000
# Latest bar volume divided by recent average bar volume. Logged and used as a
# strategy-specific filter by default; set ENFORCE_RELATIVE_VOLUME_FILTER=true
# only if you intentionally want it as a global universe gate.
MIN_RELATIVE_VOLUME=0.0
ENFORCE_RELATIVE_VOLUME_FILTER=false
MAX_SPREAD_PCT=1.0

# Additional risk + runtime guards
TRADING_START=09:30
TRADING_END=16:00
ALLOW_AFTER_HOURS=false
EXTENDED_HOURS_ENABLED=false
BROKER_EXTENDED_HOURS_SUPPORTED=false
OVERNIGHT_TRADING_ENABLED=false
USE_LIMIT_ORDERS_IN_EXTENDED_HOURS=true
LIMIT_ORDER_AGGRESSIVENESS_PCT=0.001
FORCE_FLATTEN_BEFORE_SESSION_END=false
FLATTEN_BUFFER_MINUTES=10
ALLOW_OVERNIGHT_POSITIONS=false
MAX_TRADES_PER_DAY=10
MAX_TRADES_PER_SYMBOL_PER_DAY=2
SYMBOL_COOLDOWN_SECONDS=900
STRATEGY_COOLDOWN_SECONDS=300
ONE_TRADE_PER_SYMBOL_PER_SESSION=false
KILL_SWITCH_ON_STARTUP=false

# ---------------------------------------------------------------------------
# Polymarket CLOB arb scanner (src/polymarket) — scan-only, no execution
# ---------------------------------------------------------------------------
POLY_API_KEY=
POLY_API_SECRET=
POLY_PASSPHRASE=
POLY_PRIVATE_KEY=
POLY_SCAN_INTERVAL_SEC=30
POLY_MIN_EDGE_PCT=1.5
# Phase 2: execution controls (POLY_DRY_RUN=true = log only, never place real orders)
POLY_MAX_TRADE_USDC=500
POLY_MAX_POSITIONS=5
POLY_DAILY_LOSS_LIMIT=200
POLY_DRY_RUN=true
# Optional overrides (defaults shown):
# POLY_CLOB_BASE_URL=https://clob.polymarket.com
# KALSHI_BASE_URL=https://trading-api.kalshi.com/trade-api/v2
# POLY_MAX_RETRIES=3
# POLY_TIMEOUT_SECONDS=15.0
# POLY_MIN_VOLUME_24H=10000
# POLY_POSITIONS_PATH=data/polymarket_positions.json
# Live execution requires: pip install 'py-clob-client>=0.7'
# Phase 3: position monitoring
POLY_MONITOR_INTERVAL_SEC=60
POLY_TAKE_PROFIT_PCT=15.0
POLY_STOP_LOSS_PCT=10.0
POLY_MAX_HOLD_HOURS=72
POLY_UNHEDGED_GRACE_MINUTES=5
# POLY_LOG_DIR=logs

# ---------------------------------------------------------------------------
# Phase 4: unified dashboard (src/dashboard)
# ---------------------------------------------------------------------------
# Port for the combined Trauto API + dashboard server
DASHBOARD_PORT=8080
# Bearer token required for all POST dashboard actions (pause/resume/close/scan)
# Generate a long random string before going live:
#   python -c "import secrets; print(secrets.token_hex(32))"
DASHBOARD_API_TOKEN=change_me_before_going_live
